    {
      "id": "ir_rule_discuss_channel_all",
      "model": "ir.rule",
      "values": {
        "name": "discuss.channel: can access channels (as member or as group allowed)",
        "model_id": {
          "ref": "mail.model_discuss_channel"
        },
        "groups": {
          "eval": "[                     Command.link(ref('base.group_user')),                     Command.link(ref('base.group_portal')),                     Command.link(ref('base.group_public')),                 ]"
        },
        "domain_force": "\n                [\n                    \"|\",\n                        \"&\",\n                            (\"channel_type\", \"!=\", \"channel\"),\n                            \"|\",\n                                (\"is_member\", \"=\", True),\n                                (\"parent_channel_id.is_member\", \"=\", True),\n                        \"&\",\n                            (\"channel_type\", \"=\", \"channel\"),\n                            \"|\",\n                                (\"group_public_id\", \"=\", False),\n                                (\"group_public_id\", \"in\", user.all_group_ids.ids),\n                ]\n            "
      },
      "noupdate": true
    },
    {
      "id": "ir_rule_discuss_channel_group_system",
