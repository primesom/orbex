{
  "records": [
    {
      "id": "mail.channel_all_employees",
      "model": "discuss.channel",
      "values": {
        "name": "general",
        "description": "General announcements for all employees."
      },
      "noupdate": true
    },
    {
      "id": "mail.channel_admin",
      "model": "discuss.channel",
      "values": {
        "name": "Administrators",
        "description": "General channel for administrators.",
        "group_public_id": {
          "ref": "base.group_system"
        },
        "group_ids": {
          "eval": "[Command.link(ref('base.group_system'))]"
        }
      },
      "noupdate": true
    },
    {
      "id": "mail.module_install_notification",
      "model": "mail.message",
      "values": {
        "model": "discuss.channel",
        "res_id": {
          "ref": "mail.channel_all_employees"
        },
        "message_type": "email",
        "subtype_id": {
          "ref": "mail.mt_comment"
        },
        "subject": "Welcome to Orbex!",
        "body": "<p>Welcome to the #general channel.</p>\n            <p>This channel is accessible to all users to <b>easily share company information</b>.</p>"
      },
      "noupdate": true
    },
    {
      "id": "channel_member_general_channel_for_admin",
      "model": "discuss.channel.member",
      "values": {
        "partner_id": {
          "ref": "base.partner_admin"
        },
        "channel_id": {
          "ref": "mail.channel_all_employees"
        },
        "fetched_message_id": {
          "ref": "mail.module_install_notification"
        },
        "seen_message_id": {
          "ref": "mail.module_install_notification"
        }
      },
      "noupdate": true
    },
    {
      "id": "mail.channel_all_employees",
      "model": "discuss.channel",
      "values": {
        "group_ids": {
          "eval": "[Command.link(ref('base.group_user'))]"
        }
      },
      "noupdate": true
    }
  ]
}
