{
  "records": [
    {
      "id": "view_message_tree",
      "model": "ir.ui.view",
      "values": {
        "name": "mail.message.list",
        "model": "mail.message",
        "priority": "20",
        "arch": "<list string=\"Messages\">\n                    <field name=\"date\"/>\n                    <field name=\"subject\"/>\n                    <field name=\"author_id\"/>\n                    <field name=\"model\"/>\n                    <field name=\"res_id\"/>\n                </list>\n            "
      }
    },
    {
      "id": "mail_message_view_form",
      "model": "ir.ui.view",
      "values": {
        "name": "mail.message.view.form",
        "model": "mail.message",
        "priority": "20",
        "arch": "<form string=\"Message\" duplicate=\"0\">\n                    <sheet>\n                        <div class=\"oe_button_box\" name=\"button_box\">\n                            <button name=\"action_open_document\" type=\"object\" class=\"oe_link\" icon=\"fa-file-text-o\" invisible=\"not model or res_id == 0\">\n                                <div class=\"o_field_widget o_stat_info\">\n                                    <span class=\"o_stat_text\">Open Document</span>\n                                </div>\n                            </button>\n                        </div>\n                        <group>\n                            <group>\n                                <field name=\"subject\"/>\n                                <field name=\"date\"/>\n                                <field name=\"email_from\"/>\n                                <field name=\"author_id\"/>\n                                <field name=\"message_type\"/>\n                                <field name=\"subtype_id\"/>\n                                <field name=\"is_internal\"/>\n                            </group>\n                            <group>\n                                <field name=\"model\"/>\n                                <field name=\"res_id\"/>\n                                <field name=\"record_name\"/>\n                                <field name=\"parent_id\"/>\n                            </group>\n                        </group>\n                        <notebook>\n                            <page string=\"Body\" name=\"body\">\n                                <field name=\"body\" widget=\"html_mail\"/>\n                            </page>\n                            <page string=\"Gateway\" name=\"gateway\">\n                                <group>\n                                    <group>\n                                        <field name=\"reply_to\"/>\n                                        <field name=\"reply_to_force_new\"/>\n                                    </group>\n                                    <group>\n                                        <field name=\"message_id\"/>\n                                        <field name=\"mail_server_id\"/>\n                                    </group>\n                                </group>\n                            </page>\n                            <page string=\"Recipients\" name=\"recipients\">\n                                <group>\n                                    <group>\n                                        <field name=\"partner_ids\" widget=\"many2many_tags\"/>\n                                        <field name=\"incoming_email_to\"/>\n                                        <field name=\"incoming_email_cc\"/>\n                                    </group>\n                                    <group>\n                                        <field name=\"notified_partner_ids\" widget=\"many2many_tags\"/>\n                                        <field name=\"starred_partner_ids\" widget=\"many2many_tags\"/>\n                                    </group>\n                                </group>\n                                <group>\n                                    <field name=\"notification_ids\">\n                                        <list>\n                                            <field name=\"res_partner_id\"/>\n                                            <field name=\"is_read\"/>\n                                            <field name=\"notification_type\"/>\n                                            <field name=\"notification_status\"/>\n                                        </list>\n                                    </field>\n                                </group>\n                            </page>\n                            <page string=\"Tracking\" name=\"page_tracking\">\n                                <field name=\"tracking_value_ids\"/>\n                            </page>\n                        </notebook>\n                    </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "view_message_search",
      "model": "ir.ui.view",
      "values": {
        "name": "mail.message.search",
        "model": "mail.message",
        "priority": "25",
        "arch": "<search string=\"Messages Search\">\n                    <field name=\"body\" string=\"Content\" filter_domain=\"['|', ('subject', 'ilike', self), ('body', 'ilike', self)]\"/>\n                    <field name=\"subject\"/>\n                    <field name=\"message_type\"/>\n                    <field name=\"author_id\"/>\n                    <field name=\"partner_ids\"/>\n                    <field name=\"model\"/>\n                    <field name=\"res_id\"/>\n                    <field name=\"parent_id\"/>\n                    <filter string=\"Has Mentions\" name=\"filter_has_mentions\" domain=\"[('partner_ids.user_ids', 'in', [uid])]\"/>\n                    <separator/>\n                    <filter string=\"Need Action\" name=\"message_needaction\" help=\"Unread messages\" domain=\"[('needaction', '=', True)]\"/>\n                    <separator/>\n                </search>\n            "
      }
    },
    {
      "id": "action_view_mail_message",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Messages",
        "res_model": "mail.message",
        "view_mode": "list,form",
        "search_view_id": {
          "ref": "view_message_search"
        }
      }
    },
    {
      "id": "view_document_file_kanban",
      "model": "ir.ui.view",
      "values": {
        "name": "ir.attachment kanban",
        "model": "ir.attachment",
        "arch": "<kanban edit=\"false\" import=\"false\">\n                    <field name=\"id\"/>\n                    <field name=\"mimetype\"/>\n                    <field name=\"type\"/>\n                    <templates>\n                        <t t-name=\"menu\">\n                            <a t-attf-href=\"/web/content/ir.attachment/#{record.id.raw_value}/datas?download=true\" download=\"\" class=\"dropdown-item\">Download</a>\n                            <a t-if=\"widget.deletable\" role=\"menuitem\" type=\"delete\" class=\"dropdown-item\">Delete</a>\n                        </t>\n                        <t t-name=\"card\" class=\"o_kanban_attachment flex-row\">\n                            <aside class=\"o_kanban_image m-1\">\n                                <div class=\"o_kanban_image_wrapper d-flex align-items-center justify-content-center\">\n                                    <t t-set=\"webimage\" t-value=\"new RegExp('image.*(gif|jpeg|jpg|png|webp)').test(record.mimetype.value)\"/>\n                                    <div t-if=\"record.type.raw_value == 'url'\" class=\"fa fa-link fa-3x text-muted\" aria-label=\"Image is a link\"/>\n                                    <img t-elif=\"webimage\" t-attf-src=\"/web/image/#{record.id.raw_value}\" width=\"100\" height=\"100\" alt=\"Document\" class=\"o_attachment_image\"/>\n                                    <div t-else=\"!webimage\" class=\"o_image o_image_thumbnail\" t-att-data-mimetype=\"record.mimetype.value\"/>\n                                </div>\n                            </aside>\n                            <main class=\"ms-1\">\n                                <div class=\"o_kanban_details_wrapper d-flex flex-column\">\n                                    <field name=\"name\" class=\"text-truncate fw-bold fs-5\"/>\n                                    <div class=\"d-flex flex-grow-1 align-items-center\">\n                                        <t t-if=\"record.type.raw_value == 'url'\">\n                                            <i class=\"fa fa-globe\" aria-label=\"Document url\"/> <field name=\"url\" widget=\"url\"/>\n                                        </t>\n                                    </div>\n                                    <div class=\"d-flex\">\n                                        <field name=\"create_date\"/>\n                                        <field name=\"create_uid\" widget=\"many2one_avatar_user\" class=\"ms-auto\"/>\n                                    </div>\n                                </div>\n                            </main>\n                        </t>\n                    </templates>\n                </kanban>\n            "
      }
    },
    {
      "id": "base.action_attachment",
      "model": "ir.actions.act_window",
      "values": {
        "view_mode": "kanban,list,form",
        "help": "<p class=\"o_view_nocontent_smiling_face\">\n                Attach a new document\n              </p>\n            "
      }
    }
  ]
}
