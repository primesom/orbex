{
  "records": [
    {
      "id": "view_email_server_tree",
      "model": "ir.ui.view",
      "values": {
        "name": "fetchmail.server.list",
        "model": "fetchmail.server",
        "arch": "<list string=\"POP/IMAP Servers\">\n                    <field name=\"name\"/>\n                    <field name=\"server_type\"/>\n                    <field name=\"user\" readonly=\"state != 'draft'\"/>\n                    <field name=\"date\"/>\n                    <field name=\"state\" widget=\"badge\" decoration-info=\"state == 'draft'\" decoration-success=\"state == 'done'\"/>\n                </list>\n            "
      }
    },
    {
      "id": "view_email_server_form",
      "model": "ir.ui.view",
      "values": {
        "name": "fetchmail.server.form",
        "model": "fetchmail.server",
        "arch": "<form string=\"Incoming Mail Server\">\n                    <header invisible=\"server_type == 'local'\">\n                        <button string=\"Test &amp; Confirm\" type=\"object\" name=\"button_confirm_login\" invisible=\"state != 'draft'\"/>\n                        <button string=\"Fetch Now\" type=\"object\" name=\"fetch_mail\" invisible=\"state != 'done'\"/>\n                        <button string=\"Reset Confirmation\" type=\"object\" name=\"set_draft\" invisible=\"state != 'done'\"/>\n                        <field name=\"state\" widget=\"statusbar\"/>\n                    </header>\n                    <sheet>\n                    <field name=\"active\" invisible=\"1\"/>\n                    <widget name=\"web_ribbon\" title=\"Archived\" bg_color=\"text-bg-danger\" invisible=\"active\"/>\n                     <group>\n                        <group>\n                            <field name=\"name\"/>\n                            <field name=\"server_type\" widget=\"radio\" readonly=\"state == 'done'\"/>\n                        </group>\n                        <group>\n                            <field name=\"date\" invisible=\"not date\"/>\n                            <div class=\"text-muted fst-italic\" colspan=\"8\" role=\"alert\" invisible=\"not server_type_info\">\n                                <field name=\"server_type_info\"/>\n                            </div>\n                        </group>\n                     </group>\n                     <notebook>\n                        <page string=\"Server &amp; Login\" name=\"server_login_details\">\n                            <group>\n                                <group invisible=\"server_type == 'local'\" string=\"Server Information\">\n                                    <field name=\"server\" readonly=\"state != 'draft'\" required=\"server_type != 'local'\"/>\n                                    <field name=\"port\" required=\"1\" readonly=\"state != 'draft'\" options=\"{'format': false}\"/>\n                                    <field name=\"is_ssl\"/>\n                                </group>\n                                <group invisible=\"server_type == 'local'\" string=\"Login Information\">\n                                    <field name=\"user\" readonly=\"state != 'draft'\" required=\"server_type != 'local'\"/>\n                                    <field name=\"password\" password=\"True\" invisible=\"server_type not in ('imap', 'pop')\" readonly=\"state != 'draft'\" required=\"server_type in ('imap', 'pop')\"/>\n                                </group>\n                                <group string=\"Actions to Perform on Incoming Mails\">\n                                    <field name=\"object_id\"/>\n                                </group>\n                                <group invisible=\"server_type != 'local'\" string=\"Configuration\">\n                                    <field name=\"configuration\"/>\n                                    <field name=\"script\" widget=\"url\"/>\n                                </group>\n                            </group>\n                        </page>\n                        <page string=\"Advanced\" name=\"advanced_options\" groups=\"base.group_no_one\">\n                            <group>\n                                <group string=\"Advanced Options\">\n                                    <field name=\"priority\" readonly=\"state != 'draft'\"/>\n                                    <field name=\"attach\"/>\n                                    <field name=\"original\"/>\n                                </group>\n                                <group string=\"Last Error\">\n                                    <field name=\"error_date\"/>\n                                    <field name=\"error_message\"/>\n                                </group>\n                            </group>\n                        </page>\n                    </notebook>\n                  </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "view_email_server_search",
      "model": "ir.ui.view",
      "values": {
        "name": "fetchmail.server.search",
        "model": "fetchmail.server",
        "arch": "<search string=\"Search Incoming Mail Servers\">\n                    <field name=\"name\" string=\"Incoming Mail Server\"/>\n                    <field name=\"user\"/>\n                    <filter string=\"IMAP\" name=\"imap\" domain=\"[('server_type', '=', 'imap')]\" help=\"Server type IMAP.\"/>\n                    <filter string=\"POP\" name=\"pop\" domain=\"[('server_type', '=', 'pop')]\" help=\"Server type POP.\"/>\n                    <separator/>\n                    <filter string=\"SSL\" name=\"ssl\" domain=\"[('is_ssl', '=', True)]\" help=\"If SSL required.\"/>\n                    <separator/>\n                    <filter string=\"Archived\" name=\"inactive\" domain=\"[('active', '=', False)]\"/>\n                </search>\n            "
      }
    },
    {
      "id": "action_email_server_tree",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Incoming Mail Servers",
        "res_model": "fetchmail.server",
        "view_mode": "list,form",
        "view_id": {
          "ref": "view_email_server_tree"
        },
        "search_view_id": {
          "ref": "view_email_server_search"
        },
        "help": "<div>\n                    <b class=\"o_view_nocontent_smiling_face\">\n                        No Incoming Servers yet\n                    </b>\n                </div>\n            "
      }
    }
  ]
}
