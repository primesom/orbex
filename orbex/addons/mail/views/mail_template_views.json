{
  "records": [
    {
      "id": "email_template_form",
      "model": "ir.ui.view",
      "values": {
        "name": "email.template.form",
        "model": "mail.template",
        "arch": "<form string=\"Templates\" class=\"o_mail_template_form_view\">\n                    <header>\n                        <field name=\"ref_ir_act_window\" invisible=\"1\"/>\n                        <field name=\"template_fs\" invisible=\"1\"/>\n                        <field name=\"is_template_editor\" invisible=\"1\"/>\n                        <button string=\"Preview\" name=\"action_open_mail_preview\" type=\"object\" class=\"btn-primary\" target=\"new\"/>\n                        <button string=\"Reset Template\" name=\"%(mail_template_reset_action)d\" type=\"action\" groups=\"mail.group_mail_template_editor\" invisible=\"not template_fs\"/>\n                        <t groups=\"base.group_no_one\">\n                            <button string=\"Add Context Action\" class=\"btn btn-secondary\" name=\"create_action\" type=\"object\" groups=\"base.group_system\" invisible=\"ref_ir_act_window\" help=\"Display an option on related documents to open a composition wizard with this template\"/>\n                            <button string=\"Remove Context Action\" class=\"btn btn-secondary\" name=\"unlink_action\" type=\"object\" invisible=\"not ref_ir_act_window\" help=\"Remove the contextual action to use this template on related documents\"/>\n                        </t>\n                    </header>\n                    <sheet>\n                        <div class=\"oe_title\">\n                            <label for=\"name\"/>\n                            <h1><field name=\"name\" class=\"w-100\" string=\"Template Name\" required=\"1\" placeholder=\"e.g. &quot;Welcome email&quot;\"/></h1>\n                            <group>\n                                <field name=\"model_id\" groups=\"!base.group_no_one\" invisible=\"context.get('default_model')\" placeholder=\"e.g. Contact\" required=\"1\" options=\"{'no_create': True}\"/>\n                                <field name=\"model_id\" groups=\"base.group_no_one\" placeholder=\"e.g. Contact\" required=\"1\" options=\"{'no_create': True}\"/>\n                                <field name=\"subject\" options=\"{'dynamic_placeholder': true}\" placeholder=\"e.g. &quot;Welcome to MyCompany&quot; or &quot;Nice to meet you, {{ object.name }}&quot;\"/>\n                                <field name=\"model\" invisible=\"1\"/>\n                            </group>\n                        </div>\n                        <notebook>\n                            <page string=\"Body\" name=\"content\">\n                                <field name=\"can_write\" invisible=\"1\"/>\n                                <field name=\"body_html\" widget=\"html_mail\" class=\"oe-bordered-editor\" placeholder=\"Write your message here...\" options=\"{'codeview': true, 'dynamic_placeholder': true, 'allowCommandVideo': false}\" readonly=\"not can_write and id\"/>\n                                <div invisible=\"not can_write\" class=\"fst-italic text-muted\">Tip: Write /field to insert dynamic content!</div>\n                            </page>\n                            <page string=\"Settings\" name=\"email_configuration\" groups=\"base.group_no_one\">\n                                <group col=\"2\">\n                                    <group>\n                                        <separator string=\"Sender &amp; Recipients\"/>\n                                        <field name=\"email_from\" placeholder=\"Sender's email\"/>\n                                        <field name=\"use_default_to\"/>\n                                        <field name=\"email_to\" invisible=\"use_default_to\" placeholder=\"Comma-separated recipient addresses\"/>\n                                        <field name=\"partner_to\" invisible=\"use_default_to\" placeholder=\"Comma-separated ids of recipient partners\"/>\n                                        <field name=\"email_cc\" invisible=\"use_default_to\" placeholder=\"Comma-separated carbon copy of recipients addresses\"/>\n                                        <field name=\"reply_to\" placeholder=\"Capture replies in the chatter\"/>\n                                    </group>\n                                    <group>\n                                        <separator string=\"Technical\"/>\n                                        <field name=\"lang\" placeholder=\"Main partner's language\" options=\"{'dynamic_placeholder': true}\"/>\n                                        <field name=\"has_mail_server\" invisible=\"1\"/>\n                                        <field name=\"mail_server_id\" invisible=\"not has_mail_server\" placeholder=\"By order of server priority\"/>\n                                        <field name=\"auto_delete\"/>\n                                        <field name=\"scheduled_date\" string=\"Scheduled Send Date\" placeholder=\"Send Instantly\" options=\"{'dynamic_placeholder': true}\"/>\n                                    </group>\n                                </group>\n                            </page>\n                            <page string=\"Options\" name=\"email_settings\">\n                                <group col=\"2\">\n                                    <group>\n                                        <field name=\"has_dynamic_reports\" invisible=\"1\"/>\n                                        <field name=\"attachment_ids\" widget=\"many2many_binary\"/>\n                                        <field name=\"report_template_ids\" widget=\"many2many_tags\" domain=\"[('model','=',model)]\" invisible=\"not has_dynamic_reports\" options=\"{'no_create': True}\" placeholder=\"None\"/>\n                                    </group>\n                                    <group>\n                                        <field name=\"user_id\" widget=\"many2one_avatar_user\" readonly=\"not is_template_editor\" invisible=\"not is_template_editor\" placeholder=\"Shared with all users\"/>\n                                        <field name=\"description\" placeholder=\"Describe when this template should be used\"/>\n                                    </group>\n                                </group>\n                            </page>\n                        </notebook>\n                    </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "email_template_tree",
      "model": "ir.ui.view",
      "values": {
        "name": "email.template.list",
        "model": "mail.template",
        "arch": "<list string=\"Templates\">\n                    <field name=\"mail_server_id\" column_invisible=\"True\"/>\n                    <field name=\"name\"/>\n                    <field name=\"model_id\" groups=\"base.group_no_one\"/>\n                    <field name=\"user_id\" optional=\"show\" widget=\"many2one_avatar_user\"/>\n                    <field name=\"description\"/>\n                    <field name=\"subject\" optional=\"hidden\"/>\n                    <field name=\"email_from\" optional=\"hidden\"/>\n                    <field name=\"email_to\" optional=\"hidden\"/>\n                    <field name=\"partner_to\" optional=\"hidden\"/>\n                </list>\n            "
      }
    },
    {
      "id": "view_email_template_search",
      "model": "ir.ui.view",
      "values": {
        "name": "email.template.search",
        "model": "mail.template",
        "arch": "<search string=\"Templates\">\n                    <field name=\"name\" filter_domain=\"['|', '|', ('name','ilike',self), ('subject','ilike',self), ('email_to','ilike',self)]\" string=\"Templates\"/>\n                    <field name=\"lang\"/>\n                    <field name=\"model\" filter_domain=\"[('model', '=', raw_value)]\"/>\n                    <field name=\"model_id\"/>\n                    <filter name=\"my_templates\" string=\"My Templates\" domain=\"[('user_id', '=', uid)]\"/>\n                    <filter name=\"base_templates\" string=\"Base Templates\" domain=\"[('template_category', '=', 'base_template')]\"/>\n                    <filter name=\"custom_templates\" string=\"Custom Templates\" domain=\"[('template_category', '=', 'custom_template')]\"/>\n                    <group>\n                        <filter string=\"SMTP Server\" name=\"smtpserver\" domain=\"[]\" context=\"{'group_by':'mail_server_id'}\"/>\n                        <filter string=\"Model\" name=\"group_by_model_id\" domain=\"[]\" context=\"{'group_by':'model_id'}\"/>\n                    </group>\n                </search>\n            "
      }
    },
    {
      "id": "action_email_template_tree_all",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Email Templates",
        "res_model": "mail.template",
        "path": "email-templates",
        "view_mode": "form,list",
        "view_id": {
          "ref": "email_template_tree"
        },
        "search_view_id": {
          "ref": "view_email_template_search"
        },
        "context": "{'search_default_base_templates': 1}"
      }
    }
  ]
}
