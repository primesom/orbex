{
  "records": [
    {
      "id": "res_users_settings_view_tree",
      "model": "ir.ui.view",
      "values": {
        "name": "res.users.settings.list",
        "model": "res.users.settings",
        "priority": "10",
        "arch": "<list string=\"User Settings\">\n                <field name=\"id\"/>\n                <field name=\"user_id\"/>\n                <field name=\"use_push_to_talk\"/>\n            </list>\n        "
      }
    },
    {
      "id": "res_users_settings_view_form",
      "model": "ir.ui.view",
      "values": {
        "name": "res.users.settings.form",
        "model": "res.users.settings",
        "arch": "<form string=\"User Settings\">\n                <sheet>\n                    <div class=\"oe_title\">\n                        <h1><field name=\"user_id\" readonly=\"id != False\"/></h1>\n                    </div>\n                    <group name=\"discuss_user_settings\">\n                        <group string=\"Discuss sidebar\">\n                            <field name=\"is_discuss_sidebar_category_channel_open\"/>\n                            <field name=\"is_discuss_sidebar_category_chat_open\"/>\n                        </group>\n                        <group string=\"Voice\">\n                            <field name=\"use_push_to_talk\"/>\n                            <field name=\"push_to_talk_key\" placeholder=\"e.g. true.true..f\" invisible=\"not use_push_to_talk\"/>\n                            <field name=\"voice_active_duration\" invisible=\"use_push_to_talk\"/>\n                        </group>\n                    </group>\n                    <notebook colspan=\"4\">\n                        <page string=\"Volume per partner\" name=\"page_volume_per_partner\">\n                            <field name=\"volume_settings_ids\">\n                                <list editable=\"bottom\">\n                                    <field name=\"partner_id\"/>\n                                    <field name=\"volume\"/>\n                                </list>\n                            </field>\n                        </page>\n                    </notebook>\n                </sheet>\n            </form>\n        "
      }
    },
    {
      "id": "res_users_settings_action",
      "model": "ir.actions.act_window",
      "values": {
        "name": "User Settings",
        "res_model": "res.users.settings",
        "view_mode": "list,form"
      }
    }
  ]
}
