{
  "records": [
    {
      "id": "action_res_users_my_fullpage",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Change My Preferences",
        "res_model": "res.users",
        "view_mode": "form",
        "path": "my-preferences"
      }
    },
    {
      "id": "action_res_users_my_fullpage_view",
      "model": "ir.actions.act_window.view",
      "values": {
        "sequence": {
          "eval": "50"
        },
        "view_mode": "form",
        "view_id": {
          "ref": "base.view_users_form_simple_modif"
        },
        "act_window_id": {
          "ref": "mail.action_res_users_my_fullpage"
        }
      }
    },
    {
      "id": "view_users_form_simple_modif_mail",
      "model": "ir.ui.view",
      "values": {
        "name": "res.users.preferences.form.mail",
        "model": "res.users",
        "inherit_id": {
          "ref": "base.view_users_form_simple_modif"
        },
        "arch": "<data>\n                    <xpath expr=\"//group[@name='other_preferences']\" position=\"inside\">\n                        <field name=\"notification_type\" widget=\"radio\" readonly=\"0\" options=\"{'horizontal': true}\"/>\n                        <field name=\"outgoing_mail_server_id\" invisible=\"1\"/> <!-- Used by the mail_server_configurator_selection widget -->\n                        <span class=\"o_form_label fw-bold\" invisible=\"not has_external_mail_server\">Outgoing Mail Server</span>\n                        <field name=\"outgoing_mail_server_type\" nolabel=\"1\" string=\"Outgoing Mail Server\" widget=\"mail_server_configurator_selection\" invisible=\"not has_external_mail_server\"/>\n                    </xpath>\n                    <field name=\"signature\" position=\"attributes\">\n                        <attribute name=\"widget\">html_mail</attribute>\n                    </field>\n                    <group name=\"calendar_preferences\" position=\"inside\">\n                        <label for=\"out_of_office_from\" string=\"Out-of-office\"/>\n                        <div class=\"o_row\">\n                            <field name=\"out_of_office_from\" widget=\"daterange\" options=\"{'end_date_field': 'out_of_office_to', 'show_time': False}\" placeholder=\"None planned\"/>\n                            <field name=\"out_of_office_to\" invisible=\"1\"/> <!-- otherwise it is visible, smort -->\n                        </div>\n                        <field name=\"out_of_office_message\" string=\"\" options=\"{'height': 112}\" class=\"border border-secondary w-100\" placeholder=\"Your out-of-office message...\"/>\n                    </group>\n                </data>\n            "
      }
    },
    {
      "id": "view_users_form_mail",
      "model": "ir.ui.view",
      "values": {
        "name": "res.users.form.mail",
        "model": "res.users",
        "inherit_id": {
          "ref": "base.view_users_form"
        },
        "arch": "<data>\n                    <xpath expr=\"//group[@name='other_preferences']\" position=\"inside\">\n                        <field name=\"notification_type\" widget=\"radio\" invisible=\"share\" options=\"{'horizontal': true}\"/>\n                        <field name=\"outgoing_mail_server_id\" invisible=\"1\"/> <!-- Used by the mail_server_configurator_selection widget -->\n                        <span class=\"o_form_label fw-bold\" invisible=\"not has_external_mail_server\">Outgoing Mail Server</span>\n                        <field name=\"outgoing_mail_server_type\" nolabel=\"1\" string=\"Outgoing Mail Server\" widget=\"mail_server_configurator_selection\" invisible=\"not has_external_mail_server\"/>\n                    </xpath>\n                    <field name=\"signature\" position=\"attributes\">\n                        <attribute name=\"widget\">html_mail</attribute>\n                    </field>\n                    <group name=\"calendar_preferences\" position=\"inside\">\n                        <label for=\"out_of_office_from\" string=\"Out-of-office\"/>\n                        <div class=\"o_row\">\n                            <field name=\"out_of_office_from\" widget=\"daterange\" options=\"{'end_date_field': 'out_of_office_to', 'show_time': False}\" placeholder=\"None planned\"/>\n                            <field name=\"out_of_office_to\" invisible=\"1\"/> <!-- otherwise it is visible, smort -->\n                        </div>\n                        <field name=\"out_of_office_message\" string=\"\" options=\"{'height': 112}\" class=\"border border-secondary w-100\" placeholder=\"Your out-of-office message...\"/>\n                    </group>\n                </data>\n            "
      }
    }
  ]
}
