<?xml version="1.0" encoding="utf-8"?>
<orbex>
    <template id="orbex_webclient_login" inherit_id="web.login_layout">
        <xpath expr="//t[@t-call='web.frontend_layout']/t[last()]" position="after">
            <t t-set="body_classname" t-value="'o_home_menu_background'"/>
            <t t-set="login_card_classes" t-value="'rounded-0 shadow-sm bg-white'"/>
            <t t-set="disable_database_manager" t-value="1"/>
            <t t-set="disable_footer">1</t>
        </xpath>
    </template>

    <template id="orbex_webclient_bootstrap" inherit_id="web.webclient_bootstrap">
        <xpath expr="//meta[@name='theme-color']" position="replace">
            <meta name="theme-color" t-att-content="'#242733' if color_scheme == 'dark' else '#714B67'"/>
        </xpath>
    </template>


</orbex>
