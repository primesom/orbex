<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web_orbex.FormStatusIndicatorLabels" t-inherit="web.FormStatusIndicator" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_form_status_indicator_buttons')]" position="attributes">
            <attribute name="class">o_form_status_indicator_buttons d-flex gap-2</attribute>
        </xpath>

        <xpath expr="//button[hasclass('o_form_button_save')]" position="replace">
            <button
                type="button"
                class="o_form_button_save btn btn-primary"
                data-hotkey="s"
                t-on-click.stop="save"
                data-tooltip="Save"
                aria-label="Save"
                t-ref="save">
                Save
            </button>
        </xpath>

        <xpath expr="//button[hasclass('o_form_button_cancel')]" position="replace">
            <button
                type="button"
                class="o_form_button_cancel btn btn-secondary"
                data-hotkey="j"
                t-on-click.stop="discard"
                data-tooltip="Discard"
                aria-label="Discard">
                Discard
            </button>
        </xpath>
    </t>

</templates>
