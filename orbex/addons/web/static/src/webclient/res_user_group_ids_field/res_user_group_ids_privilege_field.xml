<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="web.ResUserGroupIdsPrivilegeField">
    <div class="d-flex justify-content-between w-100" t-att-class="{'o_is_implied': this.isImplied, 'o_is_disjoint': this.isDisjoint}">
        <t t-if="type == 'selection'">
            <span t-if="props.readonly" class="o_access_choice_readonly text-truncate" t-esc="selectionDisplayName"/>
            <div t-else="" class="o_access_choice_group d-inline-flex flex-wrap gap-1" role="radiogroup">
                <t t-foreach="selectionOptions" t-as="option" t-key="option[0]">
                    <button
                        type="button"
                        class="btn btn-sm o_access_choice"
                        t-att-class="{
                            active: isOptionActive(option),
                            o_is_implied_choice: isOptionImplied(option),
                        }"
                        t-att-aria-checked="isOptionActive(option)"
                        role="radio"
                        t-on-click="() => this.onSelectOption(option[0])"
                    >
                        <span t-esc="getOptionLabel(option)"/>
                    </button>
                </t>
            </div>
        </t>
        <BooleanField t-else="" t-props="props"/>
        <button t-if="isDebug" t-att-class="infoButtonClassnames" type="button" t-on-click="onClickInfoButton" tabindex="-1"/>
    </div>
</t>

</templates>
