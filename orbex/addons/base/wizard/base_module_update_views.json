{
  "records": [
    {
      "id": "view_base_module_update",
      "model": "ir.ui.view",
      "values": {
        "name": "Module Update",
        "model": "base.module.update",
        "arch": "<form string=\"Update Module List\">\n                    <separator string=\"Module Update Result\" invisible=\"state != 'done'\"/>\n                    <group invisible=\"state != 'init'\">\n                        <span class=\"o_form_label\" colspan=\"2\">Click on Update below to start the process...</span>\n                    </group>\n                    <group invisible=\"state != 'done'\">\n                        <field name=\"updated\"/>\n                        <field name=\"added\"/>\n                    </group>\n                    <footer>\n                        <div invisible=\"state != 'init'\" class=\"d-flex gap-1\">\n                            <button name=\"update_module\" string=\"Update\" type=\"object\" class=\"btn-primary\" data-hotkey=\"q\"/>\n                            <button special=\"cancel\" data-hotkey=\"x\" string=\"Cancel\" class=\"btn-secondary\"/>\n                        </div>\n                        <div invisible=\"state != 'done'\" class=\"d-flex gap-1\">\n                            <button name=\"action_module_open\" string=\"Open Apps\" type=\"object\" class=\"btn-primary\" data-hotkey=\"q\"/>\n                            <button special=\"cancel\" data-hotkey=\"x\" string=\"Close\" class=\"btn-secondary\"/>\n                        </div>\n                    </footer>\n                </form>\n            "
      }
    },
    {
      "id": "action_view_base_module_update",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Module Update",
        "res_model": "base.module.update",
        "view_mode": "form",
        "target": "new"
      }
    }
  ],
  "menus": [
    {
      "id": "menu_view_base_module_update",
      "name": "Update Apps List",
      "parent": "menu_management",
      "action": "action_view_base_module_update",
      "sequence": 40,
      "groups": [
        "base.group_no_one"
      ]
    }
  ]
}
