{
  "records": [
    {
      "id": "action_partner_deduplicate",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Deduplicate Contacts",
        "res_model": "base.partner.merge.automatic.wizard",
        "view_mode": "form",
        "target": "new",
        "context": "{'active_test': False}"
      }
    },
    {
      "id": "base_partner_merge_automatic_wizard_form",
      "model": "ir.ui.view",
      "values": {
        "name": "base.partner.merge.automatic.wizard.form",
        "model": "base.partner.merge.automatic.wizard",
        "arch": "<form string=\"Automatic Merge Wizard\" class=\"o_partner_merge_wizard\">\n                    <sheet>\n                        <group invisible=\"state != 'finished'\">\n                            <h2 colspan=\"2\">There are no more contacts to merge for this request</h2>\n                            <button name=\"%(action_partner_deduplicate)d\" string=\"Deduplicate the other Contacts\" class=\"oe_highlight\" type=\"action\" colspan=\"2\"/>\n                        </group>\n                        <p class=\"opacity-50\" invisible=\"state != 'option'\">\n                            Select the list of fields used to search for\n                            duplicated records. If you select several fields,\n                            Orbex will propose you to merge only those having\n                            all these fields in common. (not one of the fields).\n                        </p>\n                        <group invisible=\"state not in ('selection', 'finished') or number_group == 0\">\n                            <field name=\"number_group\"/>\n                        </group>\n                        <group string=\"Search duplicates based on duplicated data in\" invisible=\"state not in ('option',)\">\n                            <field name=\"group_by_email\"/>\n                            <field name=\"group_by_name\"/>\n                            <field name=\"group_by_is_company\"/>\n                            <field name=\"group_by_vat\"/>\n                            <field name=\"group_by_parent_id\"/>\n                        </group>\n                        <group string=\"Exclude contacts having\" invisible=\"state not in ('option',)\">\n                            <field name=\"exclude_contact\"/>\n                            <field name=\"exclude_journal_item\"/>\n                        </group>\n                        <separator string=\"Options\" invisible=\"state not in ('option',)\"/>\n                        <group invisible=\"state not in ('option', 'finished')\">\n                            <field name=\"maximum_group\" readonly=\"state == 'finished'\"/>\n                        </group>\n                        <separator string=\"Merge the following contacts\" invisible=\"state in ('option', 'finished')\"/>\n                        <group invisible=\"state in ('option', 'finished')\" col=\"1\">\n                            <p class=\"opacity-50\">\n                                Selected contacts will be merged together.\n                                All documents linked to one of these contacts\n                                will be redirected to the destination contact.\n                                You can remove contacts from this list to avoid merging them.\n                            </p>\n                            <group col=\"2\">\n                                <field name=\"dst_partner_id\" domain=\"[('id', 'in', partner_ids or False)]\" required=\"state == 'selection'\" context=\"{'partner_show_db_id': True}\"/>\n                            </group>\n                            <field name=\"partner_ids\" nolabel=\"1\">\n                                <list string=\"Partners\">\n                                    <field name=\"id\"/>\n                                    <field name=\"display_name\"/>\n                                    <field name=\"email\"/>\n                                    <field name=\"is_company\"/>\n                                    <field name=\"vat\"/>\n                                    <field name=\"country_id\"/>\n                                </list>\n                            </field>\n                        </group>\n                    </sheet>\n                    <footer>\n                        <button name=\"action_merge\" string=\"Merge Contacts\" class=\"oe_highlight\" type=\"object\" data-hotkey=\"q\" invisible=\"state in ('option', 'finished')\"/>\n                        <button name=\"action_skip\" string=\"Skip these contacts\" type=\"object\" invisible=\"state != 'selection'\"/>\n                        <button name=\"action_start_manual_process\" string=\"Merge with Manual Check\" data-hotkey=\"w\" type=\"object\" class=\"oe_highlight\" invisible=\"state != 'option'\"/>\n                        <button name=\"action_start_automatic_process\" string=\"Merge Automatically\" data-hotkey=\"l\" type=\"object\" class=\"oe_highlight\" confirm=\"Are you sure to execute the automatic merge of your contacts?\" invisible=\"state != 'option'\"/>\n                        <button name=\"action_update_all_process\" string=\"Merge Automatically all process\" type=\"object\" data-hotkey=\"y\" confirm=\"Are you sure to execute the list of automatic merges of your contacts?\" invisible=\"state != 'option'\"/>\n                        <button special=\"cancel\" data-hotkey=\"x\" string=\"Cancel\" type=\"object\" class=\"btn btn-secondary oe_inline\" invisible=\"state == 'finished'\"/>\n                        <button special=\"cancel\" data-hotkey=\"x\" string=\"Close\" type=\"object\" class=\"btn btn-secondary oe_inline\" invisible=\"state != 'finished'\"/>\n                    </footer>\n                </form>\n            "
      }
    },
    {
      "id": "action_partner_merge",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Merge",
        "res_model": "base.partner.merge.automatic.wizard",
        "view_mode": "form",
        "target": "new",
        "binding_model_id": {
          "ref": "base.model_res_partner"
        },
        "binding_view_types": "list,kanban"
      }
    }
  ]
}
