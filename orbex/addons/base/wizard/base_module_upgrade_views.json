{
  "records": [
    {
      "id": "view_base_module_upgrade",
      "model": "ir.ui.view",
      "values": {
        "name": "Module Upgrade",
        "model": "base.module.upgrade",
        "arch": "<form string=\"System Update\">\n                    <p>This module will trigger the uninstallation of below modules.</p>\n                    <p><strong>This operation will permanently erase all data currently stored by the modules!</strong></p>\n                    <p>If you wish to cancel the process, press the cancel button below</p>\n                    <separator string=\"Impacted Apps\"/>\n                    <field name=\"module_info\"/>\n                    <footer>\n                        <button name=\"upgrade_module\" string=\"Confirm\" type=\"object\" class=\"btn-primary\" data-hotkey=\"q\"/>\n                        <button string=\"Cancel\" class=\"btn-secondary\" name=\"upgrade_module_cancel\" type=\"object\" data-hotkey=\"x\"/>\n                    </footer>\n                </form>\n            "
      }
    },
    {
      "id": "action_view_base_module_upgrade",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Apply Schedule Upgrade",
        "res_model": "base.module.upgrade",
        "view_mode": "form",
        "target": "new"
      }
    },
    {
      "id": "view_base_module_upgrade_install",
      "model": "ir.ui.view",
      "values": {
        "name": "Module Upgrade Install",
        "model": "base.module.upgrade",
        "priority": {
          "eval": "20"
        },
        "arch": "<form string=\"Apply Schedule Upgrade\">\n                    <div><span class=\"o_form_label\">The selected modules have been updated/installed!</span></div>\n                    <div><span class=\"o_form_label\">We suggest to reload the menu tab to see the new menus (Ctrl+T then Ctrl+R).\"</span></div>\n                    <footer>\n                        <button name=\"config\" string=\"Start configuration\" type=\"object\" class=\"btn-primary\" data-hotkey=\"q\"/>\n                        <button string=\"Cancel\" class=\"btn-secondary\" special=\"cancel\" data-hotkey=\"x\"/>\n                    </footer>\n                </form>\n            "
      }
    },
    {
      "id": "action_view_base_module_upgrade_install",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Module Upgrade Install",
        "res_model": "base.module.upgrade",
        "view_mode": "form",
        "view_id": {
          "ref": "view_base_module_upgrade_install"
        },
        "target": "new"
      }
    }
  ],
  "menus": [
    {
      "id": "menu_view_base_module_upgrade",
      "name": "Apply Scheduled Upgrades",
      "parent": "menu_management",
      "action": "action_view_base_module_upgrade",
      "sequence": 50,
      "groups": [
        "base.group_no_one"
      ]
    }
  ]
}
