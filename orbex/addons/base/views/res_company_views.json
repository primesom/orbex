{
  "records": [
    {
      "id": "view_company_form",
      "model": "ir.ui.view",
      "values": {
        "name": "res.company.form",
        "model": "res.company",
        "arch": "<form string=\"Company\" duplicate=\"0\">\n                  <sheet>\n                    <div class=\"oe_button_box\" name=\"button_box\">\n                        <button class=\"oe_stat_button\" name=\"action_all_company_branches\" type=\"object\" invisible=\"not all_child_ids\" icon=\"fa-sitemap\" string=\"Branches\"/>\n                    </div>\n                    <div class=\"d-flex gap-2\">\n                        <field name=\"logo\" widget=\"contact_image\" class=\"oe_avatar text-start float-none\" nolabel=\"1\" options=\"{'size': [100,100], 'img_class': 'rounded-4'}\"/>\n                        <div class=\"oe_title\">\n                            <label for=\"name\"/>\n                            <h1>\n                                <field name=\"name\" placeholder=\"e.g. My Company\"/>\n                            </h1>\n                        </div>\n                    </div>\n                    <notebook colspan=\"4\">\n                        <page string=\"General Information\" name=\"general_info\">\n                            <group>\n                                <group>\n                                    <field name=\"partner_id\" string=\"Contact\" readonly=\"1\" required=\"0\" groups=\"base.group_no_one\"/>\n                                    <label for=\"street\" string=\"Address\"/>\n                                    <div class=\"o_address_format\">\n                                        <field name=\"street\" placeholder=\"Street...\" class=\"o_address_street\"/>\n                                        <field name=\"street2\" placeholder=\"Street 2...\" class=\"o_address_street\"/>\n                                        <field name=\"city\" placeholder=\"City\" class=\"o_address_city\"/>\n                                        <field name=\"state_id\" class=\"o_address_state\" placeholder=\"State\" options=\"{&quot;no_open&quot;: True}\"/>\n                                        <field name=\"zip\" placeholder=\"ZIP\" class=\"o_address_zip\"/>\n                                        <field name=\"country_id\" placeholder=\"Country\" class=\"o_address_country\" options=\"{&quot;no_open&quot;: True, &quot;no_create&quot;: True}\"/>\n                                    </div>\n                                    <field name=\"vat\"/>\n                                    <field name=\"company_registry_placeholder\" invisible=\"1\"/> <!-- Needed for the placeholder widget -->\n                                    <field name=\"company_registry\" options=\"{'placeholder_field': 'company_registry_placeholder'}\"/>\n                                    <field name=\"currency_id\" options=\"{'no_create': True, 'no_open': True}\" id=\"company_currency\" context=\"{'active_test': False}\"/>\n                                </group>\n                                <group>\n                                    <field name=\"phone\" class=\"o_force_ltr\"/>\n                                    <field name=\"email\"/>\n                                    <field name=\"website\" string=\"Website\" widget=\"url\" placeholder=\"e.g. https://www.orbexsuite.com\"/>\n                                    <field name=\"parent_id\" groups=\"base.group_no_one\"/>\n                                    <field name=\"color\" widget=\"color_picker\"/>\n                                </group>\n                                <group name=\"social_media\"/>\n                            </group>\n                        </page>\n                        <page string=\"Branches\" name=\"branches\">\n                            <field name=\"child_ids\" nolabel=\"1\" context=\"{'default_parent_id': id}\"/>\n                        </page>\n                    </notebook>\n                    </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "view_company_tree",
      "model": "ir.ui.view",
      "values": {
        "name": "res.company.list",
        "model": "res.company",
        "arch": "<list string=\"Companies\" decoration-muted=\"not active\">\n                    <field name=\"sequence\" widget=\"handle\"/>\n                    <field name=\"logo\" invisible=\"not logo\" widget=\"image\" options=\"{'size': [24, 24], 'img_class': 'o_avatar rounded'}\" width=\"30\" nolabel=\"1\"/>\n                    <field name=\"name\"/>\n                    <field name=\"partner_id\" required=\"0\"/>\n                    <field name=\"child_ids\" widget=\"many2many_tags\" options=\"{'color_field': 'color'}\"/>\n                </list>\n            "
      }
    },
    {
      "id": "view_res_company_kanban",
      "model": "ir.ui.view",
      "values": {
        "name": "res.company.kanban",
        "model": "res.company",
        "arch": "<kanban>\n                    <templates>\n                        <t t-name=\"card\">\n                            <div t-attf-class=\"#{!selection_mode ? 'text-center' : ''}\">\n                                <i class=\"fa fa-building\" role=\"img\" aria-label=\"Enterprise\" title=\"Enterprise\"/> <field class=\"fw-bold fs-5\" name=\"name\"/>\n                            </div>\n                            <hr class=\"mt4 mb4\"/>\n                            <div class=\"row\" t-if=\"!selection_mode\">\n                                <div t-if=\"record.email.value\" class=\"col-6 text-center\">\n                                    <strong>Email:</strong>\n                                </div>\n                                <div t-if=\"record.phone.value\" class=\"col-6 text-center\">\n                                    <strong>Phone</strong>\n                                </div>\n                                <div t-if=\"record.email.value\" class=\"col-6 text-center\">\n                                    <field name=\"email\"/>\n                                </div>\n                                <div t-if=\"record.phone.value\" class=\"col-6 text-center o_force_ltr\">\n                                    <field name=\"phone\"/>\n                                </div>\n                            </div>\n                            <div t-else=\"\">\n                                <div t-if=\"record.email.value\">\n                                    <strong>Email:</strong>\n                                    <field name=\"email\"/>\n                                </div>\n                                <div t-if=\"record.phone.value\" class=\"o_force_ltr\">\n                                    <strong>Phone:</strong>\n                                    <field name=\"phone\"/>\n                                </div>\n                            </div>\n                        </t>\n                    </templates>\n                </kanban>\n            "
      }
    },
    {
      "id": "action_res_company_form",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Companies",
        "res_model": "res.company",
        "path": "companies",
        "view_mode": "list,kanban,form",
        "domain": "[('parent_id', '=', False)]",
        "help": "<p class=\"o_view_nocontent_smiling_face\">\n                Create a new company\n              </p><p>\n                Create and manage the companies that will be managed by Orbex from here. Shops or subsidiaries can be created and maintained from here.\n              </p>\n            "
      }
    }
  ],
  "menus": [
    {
      "id": "menu_action_res_company_form",
      "name": null,
      "parent": "base.menu_users",
      "action": "action_res_company_form"
    }
  ]
}
