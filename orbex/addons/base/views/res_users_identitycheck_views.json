{
  "records": [
    {
      "id": "res_users_identitycheck_view_form",
      "model": "ir.ui.view",
      "values": {
        "model": "res.users.identitycheck",
        "arch": "<form string=\"Password Confirmation\">\n                    <sheet>\n                        <div invisible=\"auth_method != 'password'\">\n                            <h3><strong>Let's first confirm it's you. Enter your current password:</strong></h3>\n                            <div>\n                                <field class=\"o_field_highlight col-10 col-md-6 px-0\" name=\"password\" autocomplete=\"current-password\" required=\"auth_method == 'password'\" password=\"True\" placeholder=\"Enter your password\"/>\n                            </div>\n                            <a href=\"/web/reset_password/\" class=\"btn btn-link ps-0\" role=\"button\">Forgot password?</a>\n                        </div>\n                    </sheet>\n                    <footer>\n                        <button string=\"Confirm Password\" id=\"password_confirm\" type=\"object\" name=\"run_check\" class=\"btn btn-primary\" data-hotkey=\"q\" invisible=\"auth_method != 'password'\" context=\"{'password': password}\"/>\n                        <button string=\"Discard\" special=\"cancel\" data-hotkey=\"z\" class=\"btn btn-secondary\"/>\n                    </footer>\n                </form>\n            "
      }
    }
  ]
}
