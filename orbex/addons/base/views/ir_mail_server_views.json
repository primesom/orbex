{
  "records": [
    {
      "id": "ir_mail_server_form",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.mail_server",
        "arch": "<form string=\"Outgoing Mail Servers\">\n                    <header>\n                        <button string=\"Test Connection\" type=\"object\" name=\"test_smtp_connection\" class=\"btn-primary\"/>\n                    </header>\n                    <sheet>\n                        <widget name=\"web_ribbon\" title=\"Archived\" bg_color=\"text-bg-danger\" invisible=\"active\"/>\n                        <group>\n                            <group>\n                                <field name=\"name\" placeholder=\"e.g. My Outgoing Server\"/>\n                                <field name=\"from_filter\" placeholder=\"e.g. email@domain.com, domain.com\"/>\n                            </group>\n                            <group>\n                                <field name=\"sequence\"/>\n                                <div colspan=\"2\" class=\"d-flex justify-content-between\">\n                                    <div>\n                                        <label for=\"max_email_size\" string=\"Convert attachments to links for emails over\"/>\n                                        <field name=\"max_email_size\" class=\"oe_inline mx-1\"/>\n                                        <span class=\"o_form_label\">MB</span>\n                                    </div>\n                                    <button class=\"btn btn-link pt-0\" type=\"object\" name=\"action_retrieve_max_email_size\">\n                                        <i class=\"fa fa-gear\"/> Detect Max Limit\n                                    </button>\n                                </div>\n                            </group>\n                        </group>\n                        <group>\n                            <group>\n                                <field name=\"smtp_authentication\" widget=\"radio\"/>\n                            </group>\n                            <group>\n                                <div class=\"text-muted fst-italic\" role=\"alert\" colspan=\"2\" invisible=\"not smtp_authentication_info\">\n                                    <field name=\"smtp_authentication_info\"/>\n                                </div>\n                            </group>\n                        </group>\n                        <notebook colspan=\"4\" invisible=\"smtp_authentication == 'cli'\">\n                            <page name=\"connection\" string=\"Connection\">\n                                <group>\n                                    <group>\n                                        <field name=\"smtp_encryption\" widget=\"radio\"/>\n                                        <field name=\"smtp_debug\" groups=\"base.group_no_one\"/>\n                                        <field name=\"smtp_host\" required=\"smtp_authentication != 'cli'\"/>\n                                        <field name=\"smtp_port\" options=\"{'format': false}\" required=\"smtp_authentication != 'cli'\"/>\n                                    </group>\n                                    <group>\n                                        <label for=\"smtp_user\" string=\"Username\" invisible=\"smtp_authentication == 'certificate'\"/>\n                                        <field name=\"smtp_user\" invisible=\"smtp_authentication == 'certificate'\" force_save=\"1\" nolabel=\"1\"/>\n                                        <field name=\"smtp_pass\" invisible=\"smtp_authentication != 'login'\" password=\"True\" force_save=\"1\"/>\n                                        <field name=\"smtp_ssl_certificate\" invisible=\"smtp_authentication != 'certificate'\" force_save=\"1\"/>\n                                        <field name=\"smtp_ssl_private_key\" invisible=\"smtp_authentication != 'certificate'\" force_save=\"1\"/>\n                                    </group>\n                                </group>\n                            </page>\n                        </notebook>\n                    </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "ir_mail_server_list",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.mail_server",
        "arch": "<list string=\"Outgoing Mail Servers\">\n                    <field name=\"sequence\" widget=\"handle\"/>\n                    <field name=\"name\"/>\n                    <field name=\"smtp_host\"/>\n                    <field name=\"smtp_user\"/>\n                    <field name=\"smtp_encryption\"/>\n                    <field name=\"from_filter\" optional=\"hide\"/>\n                </list>\n            "
      }
    },
    {
      "id": "view_ir_mail_server_search",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.mail_server",
        "arch": "<search string=\"Outgoing Mail Servers\">\n                    <field name=\"name\" filter_domain=\"['|', '|',                                         ('name', 'ilike', self),                                         ('smtp_host', 'ilike', self),                                         ('smtp_user', 'ilike', self)]\" string=\"Outgoing Mail Server\"/>\n                    <field name=\"smtp_encryption\"/>\n                    <field name=\"from_filter\"/>\n                    <separator/>\n                    <filter string=\"Archived\" name=\"inactive\" domain=\"[('active', '=', False)]\"/>\n                </search>\n            "
      }
    },
    {
      "id": "action_ir_mail_server_list",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Outgoing Mail Servers",
        "res_model": "ir.mail_server",
        "view_mode": "list,form",
        "view_id": {
          "ref": "ir_mail_server_list"
        },
        "search_view_id": {
          "ref": "view_ir_mail_server_search"
        },
        "help": "<div>\n                    <b class=\"o_view_nocontent_smiling_face\">\n                        No Outgoing Servers yet\n                    </b>\n                </div>\n            "
      }
    }
  ],
  "menus": [
    {
      "id": "menu_mail_servers",
      "name": null,
      "parent": "menu_email",
      "action": "action_ir_mail_server_list",
      "sequence": 5,
      "groups": [
        "base.group_no_one"
      ]
    }
  ]
}
