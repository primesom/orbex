{
  "records": [
    {
      "id": "sequence_view",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.sequence",
        "arch": "<form string=\"Sequences\">\n                  <sheet>\n                    <group>\n                      <group>\n                        <field name=\"name\"/>\n                        <field name=\"implementation\"/>\n                      </group>\n                      <group>\n                        <field name=\"code\"/>\n                        <field name=\"active\" widget=\"boolean_toggle\"/>\n                        <field name=\"company_id\" groups=\"base.group_multi_company\"/>\n                      </group>\n                    </group>\n                    <notebook>\n                    <page string=\"Sequence\" name=\"sequence\">\n                        <group>\n                          <group>\n                            <field name=\"prefix\"/>\n                            <field name=\"suffix\"/>\n                            <field name=\"use_date_range\"/>\n                          </group>\n                          <group>\n                            <field name=\"padding\"/>\n                            <field name=\"number_increment\"/>\n                            <field name=\"number_next_actual\" string=\"Next Number\" invisible=\"use_date_range\"/>\n                          </group>\n                        </group>\n                        <field name=\"date_range_ids\" invisible=\"not use_date_range\">\n                            <list string=\"Sequences\" editable=\"top\">\n                                <field name=\"date_from\"/>\n                                <field name=\"date_to\"/>\n                                <field name=\"number_next_actual\" string=\"Next Number\"/>\n                            </list>\n                        </field>\n                        <group col=\"4\" string=\"Legend (for prefix, suffix)\">\n                            <group>\n                                <span colspan=\"2\">Current Year with Century: %%(year)s</span>\n                                <span colspan=\"2\">Current Year without Century: %%(y)s</span>\n                                <span colspan=\"2\">Month: %%(month)s</span>\n                                <span colspan=\"2\">Day: %%(day)s</span>\n                            </group>\n                            <group>\n                                <span colspan=\"2\">Day of the Year: %%(doy)s</span>\n                                <span colspan=\"2\">Week of the Year: %%(woy)s</span>\n                                <span colspan=\"2\">Day of the Week (0:Monday): %%(weekday)s</span>\n                            </group>\n                            <group>\n                                <span colspan=\"2\">Hour 00-&gt;24: %%(h24)s</span>\n                                <span colspan=\"2\">Hour 00-&gt;12: %%(h12)s</span>\n                                <span colspan=\"2\">Minute: %%(min)s</span>\n                                <span colspan=\"2\">Second: %%(sec)s</span>\n                            </group>\n                            <group>\n                                <span colspan=\"2\">ISO 8601 Week Year with Century: %%(isoyear)s</span>\n                                <span colspan=\"2\">ISO 8601 Week Year without Century: %%(isoy)s</span>\n                                <span colspan=\"2\">ISO 8601 Week Number: %%(isoweek)s</span>\n                            </group>\n                        </group>\n                        <group invisible=\"not use_date_range\">\n                            <div colspan=\"2\">\n                                When subsequences per date range are used, you can prefix variables with 'range_'\n                                to use the beginning of the range instead of the current date, e.g. %%(range_year)s instead of %%(year)s.\n                            </div>\n                        </group>\n                    </page>\n                    </notebook>\n                   </sheet>\n                </form>\n            "
      }
    },
    {
      "id": "sequence_view_tree",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.sequence",
        "arch": "<list string=\"Sequences\">\n                    <field name=\"code\"/>\n                    <field name=\"name\"/>\n                    <field name=\"prefix\"/>\n                    <field name=\"padding\"/>\n                    <field name=\"company_id\" groups=\"base.group_multi_company\"/>\n                    <field name=\"number_next_actual\" string=\"Next Number\"/>\n                    <field name=\"number_increment\"/>\n                    <field name=\"implementation\"/>\n                </list>\n            "
      }
    },
    {
      "id": "view_sequence_search",
      "model": "ir.ui.view",
      "values": {
        "model": "ir.sequence",
        "arch": "<search string=\"Sequences\">\n                    <field name=\"name\" string=\"Sequence\"/>\n                    <field name=\"code\"/>\n                    <field name=\"company_id\" groups=\"base.group_multi_company\"/>\n                    <separator/>\n                    <filter string=\"Archived\" name=\"inactive\" domain=\"[('active', '=', False)]\"/>\n                </search>\n            "
      }
    },
    {
      "id": "ir_sequence_form",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Sequences",
        "res_model": "ir.sequence",
        "view_id": {
          "ref": "sequence_view_tree"
        },
        "context": "{'active_test': False}"
      }
    }
  ],
