{
  "records": [
    {
      "id": "res_users_identitycheck_view_form_passkey",
      "model": "ir.ui.view",
      "values": {
        "model": "res.users.identitycheck",
        "inherit_id": {
          "ref": "base.res_users_identitycheck_view_form"
        },
        "arch": "<data><xpath expr=\"//form\" position=\"attributes\">\n                <attribute name=\"js_class\">auth_passkey_identity_check_view_form</attribute>\n            </xpath>\n            <xpath expr=\"//sheet\" position=\"inside\">\n                <div invisible=\"auth_method != 'webauthn'\">\n                    <h3><strong>Use your passkey to authenticate</strong></h3>\n                    <p class=\"mb-0 mt-3\">Or choose a different method:</p>\n                    <button type=\"object\" name=\"action_use_password\" class=\"btn btn-link\" role=\"button\">Use password</button>\n                </div>\n            </xpath>\n            <xpath expr=\"//footer/button[@id='password_confirm']\" position=\"before\">\n                <button string=\"Use Passkey\" type=\"object\" name=\"run_check\" class=\"btn btn-primary\" data-hotkey=\"q\" invisible=\"auth_method != 'webauthn'\" context=\"{'password': password}\"/>\n            </xpath>\n        </data>"
      }
    }
  ]
}
