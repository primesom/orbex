{
  "records": [
    {
      "id": "rule_auth_passkey_key_user",
      "model": "ir.rule",
      "values": {
        "name": "Passkeys: Users can only access own Passkeys",
        "model_id": {
          "ref": "model_auth_passkey_key"
        },
        "groups": {
          "eval": "[             (4, ref('base.group_portal')),             (4, ref('base.group_user')),         ]"
        },
        "domain_force": "[('create_uid', '=', user.id)]"
      },
      "noupdate": true
    },
    {
      "id": "rule_auth_passkey_key_create_portal",
      "model": "ir.rule",
      "values": {
        "name": "Passkeys: Users can only modify their own Passkey creation requests",
        "model_id": {
          "ref": "auth_passkey.model_auth_passkey_key_create"
        },
        "groups": {
          "eval": "[             (4, ref('base.group_portal')),             (4, ref('base.group_user')),         ]"
        },
        "domain_force": "[('create_uid', '=', user.id)]"
      },
      "noupdate": true
    },
    {
      "id": "rule_auth_passkey_key_admin",
      "model": "ir.rule",
      "values": {
        "name": "Passkeys: Admins can view and delete other peoples Passkeys",
        "model_id": {
          "ref": "model_auth_passkey_key"
        },
        "groups": {
          "eval": "[(4, ref('base.group_erp_manager'))]"
        },
        "domain_force": "[(1, '=', 1)]",
        "perm_unlink": {
          "eval": "1"
        },
        "perm_write": {
          "eval": "0"
        },
        "perm_read": {
          "eval": "1"
        },
        "perm_create": {
          "eval": "0"
        }
      },
      "noupdate": true
    }
  ]
}
