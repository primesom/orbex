{
  "records": [
    {
      "id": "tour_form",
      "model": "ir.ui.view",
      "values": {
        "model": "web_tour.tour",
        "arch": "<form create=\"0\">\n                <header>\n                    <div>\n                        <field name=\"name\" widget=\"tour_start_widget\"/>\n                    </div>\n                </header>\n                <sheet>\n                    <div class=\"oe_title\">\n                        <h1><field class=\"text-break\" options=\"{'line_breaks': False}\" widget=\"text\" name=\"name\" placeholder=\"e.g. My_Tour\"/></h1>\n                    </div>\n                    <group>\n                        <group>\n                            <field name=\"sequence\"/>\n                            <field name=\"url\"/>\n                        </group>\n                        <group>\n                            <field name=\"custom\" readonly=\"1\"/>\n                            <field name=\"sharing_url\" widget=\"CopyClipboardURL\"/>\n                        </group>\n                        <notebook>\n                            <page name=\"steps\" string=\"Steps\" invisible=\"not custom\">\n                                <field name=\"step_ids\">\n                                    <list>\n                                        <field name=\"sequence\" widget=\"handle\"/>\n                                        <field name=\"trigger\"/>\n                                        <field name=\"run\"/>\n                                        <field name=\"tooltip_position\"/>\n                                        <field name=\"content\"/>\n                                    </list>\n                                </field>\n                            </page>\n                        </notebook>\n                        <field colspan=\"2\" name=\"rainbow_man_message\" placeholder=\"Rainbow Man Message...\"/>\n                    </group>\n                </sheet>\n            </form>\n        "
      }
    },
    {
      "id": "tour_list",
      "model": "ir.ui.view",
      "values": {
        "model": "web_tour.tour",
        "arch": "<list string=\"Menu\" create=\"0\" edit=\"0\" js_class=\"tour_list\">\n                <field name=\"sequence\" widget=\"handle\"/>\n                <field name=\"name\"/>\n                <field name=\"url\"/>\n                <field name=\"custom\"/>\n                <field name=\"rainbow_man_message\" column_invisible=\"1\"/> <!-- Invisible to get the data in JS -->\n                <field name=\"name\" widget=\"tour_start_widget\" options=\"{'link': true}\" string=\"\"/>\n            </list>\n        "
      }
    },
    {
      "id": "tour_search",
      "model": "ir.ui.view",
      "values": {
        "name": "tour.search",
        "model": "web_tour.tour",
        "arch": "<search string=\"Tip\">\n                <field name=\"name\"/>\n            </search>\n        "
      }
    },
    {
      "id": "tour_action",
      "model": "ir.actions.act_window",
      "values": {
        "name": "Tours",
        "res_model": "web_tour.tour",
        "view_id": {
          "ref": "tour_list"
        },
        "search_view_id": {
          "ref": "tour_search"
        }
      }
    },
    {
      "id": "tour_export_js_action",
      "model": "ir.actions.server",
      "values": {
        "name": "Export JS",
        "model_id": {
          "ref": "web_tour.model_web_tour_tour"
        },
        "binding_model_id": {
          "ref": "web_tour.model_web_tour_tour"
        },
        "binding_view_types": "form",
        "state": "code",
        "code": "\nif records:\n    action = records.export_js_file()\n        "
      }
    }
  ],
  "menus": [
    {
      "id": "menu_tour_action",
      "name": null,
      "parent": "base.next_id_2",
      "action": "tour_action",
      "sequence": 5
    }
  ]
}
